<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Senses — Biodiversity Explorer</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond&family=Josefin+Sans&family=IM+Fell+English&display=swap" rel="stylesheet">

<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>
body { margin:0; font-family:serif; background:#1a1428; color:#f0ead8; }
.hero { padding:20px; text-align:center; }
.loc-input { padding:10px; width:260px; }
button { padding:10px; cursor:pointer; }

.layout {
  display:grid;
  grid-template-columns: 1fr 1fr;
  height: calc(100vh - 140px);
}

#map {
  height:100%;
}

.grid {
  overflow:auto;
  padding:10px;
  display:grid;
  grid-template-columns:1fr;
  gap:10px;
}

.card {
  border:1px solid rgba(255,255,255,0.1);
  padding:10px;
  border-radius:10px;
  background:rgba(255,255,255,0.03);
}

.tabs { text-align:center; margin:10px; }
.tab { margin:5px; }
.active { background:#c9a84c; }

.toast {
  position:fixed; bottom:20px; left:50%;
  transform:translateX(-50%);
  background:#000; padding:10px 20px;
  opacity:0; transition:0.3s;
}
.toast.show { opacity:1; }
</style>
</head>

<body>

<div class="hero">
  <h2>Biodiversity Explorer</h2>

  <input id="loc" class="loc-input" placeholder="Search location">
  <button onclick="search()">Search</button>
  <button onclick="gps()">📍</button>
</div>

<div class="tabs">
  <button class="tab active" onclick="setType('bird')">Birds</button>
  <button class="tab" onclick="setType('plant')">Plants</button>
</div>

<div class="layout">
  <div id="map"></div>
  <div class="grid" id="grid"></div>
</div>

<div class="toast" id="toast"></div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
const KEY = "pk.20035ccf65b5e38e8e2a1e986fc979f4";

let lat = 51.5;
let lng = -0.1;
let type = "bird";
let map;
let markers = [];
let cache = {};

const DATA = {
  bird: [
    { name:"Blackbird", id:5789749 },
    { name:"Robin", id:2492295 },
    { name:"Skylark", id:2491576 }
  ],
  plant: [
    { name:"Lavender", id:3172453 },
    { name:"Rose", id:3032856 },
    { name:"Heather", id:2876946 }
  ]
};

/* ================= MAP ================= */
function initMap(){
  map = L.map('map').setView([lat,lng], 10);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution:'© OpenStreetMap'
  }).addTo(map);
}

function clearMarkers(){
  markers.forEach(m => map.removeLayer(m));
  markers = [];
}

/* ================= UI ================= */
function setType(t){
  type = t;
  document.querySelectorAll(".tab").forEach(b=>b.classList.remove("active"));
  event.target.classList.add("active");
  load();
}

/* ================= LOAD ================= */
async function load(){
  const grid = document.getElementById("grid");
  grid.innerHTML = "";
  clearMarkers();

  for(const item of DATA[type]){
    const key = `${item.id}-${lat.toFixed(2)}-${lng.toFixed(2)}`;

    let count;
    if(cache[key]){
      count = cache[key];
    } else {
      const url = `https://api.gbif.org/v1/occurrence/search?taxonKey=${item.id}&limit=0&decimalLatitude=${lat-0.5},${lat+0.5}&decimalLongitude=${lng-0.5},${lng+0.5}`;
      const res = await fetch(url);
      const data = await res.json();
      count = data.count || 0;
      cache[key] = count;
    }

    const div = document.createElement("div");
    div.className = "card";
    div.innerHTML = `<b>${item.name}</b><br>${count.toLocaleString()} records`;
    grid.appendChild(div);

    if(count > 0){
      const marker = L.marker([lat + Math.random()*0.2, lng + Math.random()*0.2])
        .addTo(map)
        .bindPopup(`${item.name}<br>${count} records`);
      markers.push(marker);
    }
  }
}

/* ================= LOCATION ================= */
async function search(){
  const q = document.getElementById("loc").value;
  const res = await fetch(`https://us1.locationiq.com/v1/search.php?key=${KEY}&q=${q}&format=json`);
  const data = await res.json();

  if(!data.length) return toast("Not found");

  lat = parseFloat(data[0].lat);
  lng = parseFloat(data[0].lon);

  map.setView([lat,lng], 10);

  toast("Updated location");
  load();
}

function gps(){
  navigator.geolocation.getCurrentPosition(async p=>{
    lat = p.coords.latitude;
    lng = p.coords.longitude;
    map.setView([lat,lng], 10);
    toast("GPS updated");
    load();
  });
}

/* ================= TOAST ================= */
function toast(msg){
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"),2000);
}

/* ================= INIT ================= */
initMap();
load();
</script>

</body>
</html>
